generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// Comando $npx prisma db push para criar a tabela no banco de dados
//Comando $npm prisma pull - Sincroniza o schema.prisma com o banco de dados
//Comando $npx prisma migrate dev --name init - Cria uma migração para criar a tabela no banco de dados
model User {
  id        Int      @id @default(autoincrement())
  name      String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String   @unique
  posts     Post[]

  @@map("users")
}
model Post {
  id       Int    @id @default(autoincrement())
  title    String
  subtitle String?
  body     String
  userId   Int    @map("userId")
  user     User   @relation(fields: [userId], references: [id])

  @@map("posts")
}
